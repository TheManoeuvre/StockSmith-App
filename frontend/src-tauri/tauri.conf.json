{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StockSmith",
  "version": "0.1.0",
  "identifier": "com.stocksmith.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "StockSmith",
        "width": 800,
        "height": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/stocksmith-backend"],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk4QTUwODMyNkQ1NDM5RkQKUldUOU9WUnRNZ2lsbUpOTGN0Smh2YXJDN0ZlOEdud1Z6djFNazZBUitINEFJemFsbUJGOCtiOTAK",
      "endpoints": ["https://github.com/TheManoeuvre/StockSmith-App/releases/latest/download/latest.json"],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
