# SQLite is the primary path (used by the packaged desktop app too) — plain file, no
# server to run. Point at Postgres instead only if you want to exercise that dev path:
#   DATABASE_URL=postgresql+asyncpg://stocksmith:stocksmith@localhost:5432/stocksmith
DATABASE_URL=sqlite+aiosqlite:///./dev.db
ASSET_ROOT=C:\Users\Benja\OneDrive\StockSmith-data
SHARED_PASSWORD_HASH=

# Etsy integration (all optional — the app runs with zero Etsy connection until these
# are set). Register an app at https://www.etsy.com/developers/register to get the
# client id/secret.
ETSY_CLIENT_ID=
ETSY_CLIENT_SECRET=
# This backend's externally-reachable URL, used to build the OAuth redirect_uri
# (must be https:// and match the redirect URI registered with the Etsy app).
PUBLIC_BASE_URL=
ETSY_POLL_INTERVAL_MINUTES=15

# eBay integration (all optional — the app runs with zero eBay connection until these
# are set). Register an app at https://developer.ebay.com/my/keys to get the client
# id/secret. EBAY_RU_NAME is NOT a URL — it's the RuName eBay generates when you
# register a redirect configuration under Application Keys > User Tokens; the real
# callback URL (PUBLIC_BASE_URL + /api/v1/platforms/ebay/callback) is entered directly
# into that dev-portal form, not here.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_RU_NAME=

# Symmetric key used to encrypt Etsy OAuth tokens at rest. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required before an Etsy connection can be created or read.
TOKEN_ENCRYPTION_KEY=
